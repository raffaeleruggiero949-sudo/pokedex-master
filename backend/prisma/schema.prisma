// Schema UNIFICATO (da usare sia in backend che in pokedex-next)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // NON inserire l'URL qui in Prisma 7! (Usa il file .env)
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userCards UserCard[]
}

model Set {
  id          String  @id
  name        String
  series      String
  totalCards  Int
  releaseDate String
  logoUrl     String?
  symbolUrl   String? // Recuperato dal backend
  language    String  @default("EN") // Recuperato dal frontend
  cards       Card[]
}

model Card {
  id         String     @id
  name       String
  supertype  String?
  subtypes   String[] // Recuperato dal backend (fondamentale per le carte ex, V, ecc.)
  rarity     String?
  priceUsd   Float?
  imageUrl   String?
  language   String     @default("EN")
  hasReverse Boolean    @default(false)
  setId      String
  set        Set        @relation(fields: [setId], references: [id])
  userCards  UserCard[]
}

model UserCard {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  variant   String   @default("Normal")
  condition String   @default("NM")
  createdAt DateTime @default(now())

  @@unique([userId, cardId, variant])
}
