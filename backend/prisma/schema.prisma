// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // NON inserire l'URL qui in Prisma 7!
}

model User {
  id        String     @id @default(uuid())
  name      String?
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  userCards UserCard[]
}

model Set {
  id          String   @id 
  name        String
  series      String   
  totalCards  Int      
  releaseDate String   
  logoUrl     String?  
  symbolUrl   String?  
  cards       Card[]   
}

model Card {
  id         String     @id 
  name       String     
  supertype  String  
  subtypes   String[]   
  rarity     String?
  language   String     @default("IT") // Aggiunto per filtrare IT/JP
  priceUsd   Float?     
  imageUrl   String     
  setId      String     
  set        Set        @relation(fields: [setId], references: [id])
  userCards  UserCard[] 
}

model UserCard {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1) 
  createdAt DateTime @default(now())

  @@unique([userId, cardId]) 
}