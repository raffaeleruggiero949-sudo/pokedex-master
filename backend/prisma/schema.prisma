generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userCards   UserCard[]
  decks       Deck[]
  priceAlerts PriceAlert[]
  notifications Notification[]
}

model Set {
  id          String   @id 
  name        String
  series      String   
  totalCards  Int      
  releaseDate String   
  logoUrl     String?  
  symbolUrl   String?  
  language    String   @default("EN") 
  cards       Card[]   
}

model Card {
  id          String     @id 
  name        String     
  supertype   String?  
  subtypes    String[]   
  rarity      String?
  priceUsd    Float?     
  imageUrl    String?     
  language    String     @default("EN") 
  hasReverse  Boolean    @default(false) 
  setId       String     
  set         Set        @relation(fields: [setId], references: [id])
  
  userCards   UserCard[] 
  deckCards   DeckCard[]
  priceAlerts PriceAlert[]
}

model UserCard {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1) 
  variant   String   @default("Normal") 
  condition String   @default("NM")     
  createdAt DateTime @default(now())

  @@unique([userId, cardId, variant]) 
}

model Deck {
  id          String     @id @default(uuid())
  name        String
  description String?
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards       DeckCard[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model DeckCard {
  id        String   @id @default(uuid())
  deckId    String
  deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)

  @@unique([deckId, cardId])
}

model PriceAlert {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId      String
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  targetPrice Float
  isCondition String   @default("Normal")
  isActive    Boolean  @default(true)      // <-- IL NUOVO CAMPO AGGIUNTO
  createdAt   DateTime @default(now())

  @@unique([userId, cardId, isCondition])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String   
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}